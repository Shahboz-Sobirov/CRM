# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.replit.dev,.repl.co,.replit.app

# CSRF (Replit domains trusted by default)
CSRF_TRUSTED_ORIGINS=https://*.replit.dev,https://*.repl.co,https://*.replit.app

# Database Configuration
# Default: SQLite (works out of the box, no setup needed).
# For PostgreSQL (e.g. Replit DB / Neon), set these:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=oxford_crm
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# JWT Settings (minutes)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440
